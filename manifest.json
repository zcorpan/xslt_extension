{
  "manifest_version": 3,
  "name": "XSLT Polyfill",
  "version": "1.0.17",
  "description": "Applies an XSLT polyfill to all XML documents.",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js",
        "xslt-polyfill.min.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "xslt_extension@mozilla.com",
      "strict_min_version": "150.0"
    }
  }
}

